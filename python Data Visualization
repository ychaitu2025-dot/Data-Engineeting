# ============================================================================
# 13) REAL-WORLD EXAMPLE: COMPREHENSIVE ANALYSIS
# ============================================================================
print("\n--- REAL-WORLD EXAMPLE: STUDENT PERFORMANCE ANALYSIS ---")

# Create comprehensive visualization
fig, axes = plt.subplots(2, 3, figsize=(15, 10))

# 1. Histogram - Distribution
axes[0, 0].hist(df["Marks"], bins=5, color="skyblue", edgecolor="black")
axes[0, 0].set_title("Marks Distribution")
axes[0, 0].set_xlabel("Marks")
axes[0, 0].set_ylabel("Frequency")

# 2. Scatter - Correlation
axes[0, 1].scatter(df["Hours_Studied"], df["Marks"], color="green", s=100)
axes[0, 1].set_title("Hours vs Marks")
axes[0, 1].set_xlabel("Hours Studied")
axes[0, 1].set_ylabel("Marks")
axes[0, 1].grid(True, alpha=0.3)

# 3. Box plot
axes[0, 2].boxplot([df["Marks"], df["Attendance"], df["Hours_Studied"]])
axes[0, 2].set_title("Distribution Comparison")
axes[0, 2].set_xticklabels(["Marks", "Attendance", "Hours"])
axes[0, 2].grid(True, alpha=0.3, axis="y")

# 4. Bar - Average by category
category_avg = df.groupby("Category")["Marks"].mean()
axes[1, 0].bar(category_avg.index, category_avg.values, color=["orange", "red", "blue"])
axes[1, 0].set_title("Average Marks by Category")
axes[1, 0].set_ylabel("Average Marks")
axes[1, 0].grid(True, alpha=0.3, axis="y")

# 5. Pie - Category distribution
category_counts = df["Category"].value_counts()
axes[1, 1].pie(category_counts.values, labels=category_counts.index, autopct="%1.1f%%")
axes[1, 1].set_title("Student Distribution")

# 6. Line - Sorted marks
axes[1, 2].plot(sorted(df["Marks"]), marker="o", color="purple")
axes[1, 2].set_title("Marks Trend (Sorted)")
axes[1, 2].set_xlabel("Student Rank")
axes[1, 2].set_ylabel("Marks")
axes[1, 2].grid(True, alpha=0.3)

plt.tight_layout()
plt.show()


